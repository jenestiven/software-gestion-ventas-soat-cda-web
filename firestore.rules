rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Solo el usuario autenticado puede leer su propio documento
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }
    
    // Cualquier usuario autenticado puede leer las sedes de venta
    match /places/{placeId} {
      allow read: if request.auth != null;
    }

    // Cualquier usuario autenticado puede leer y escribir ventas
    match /sales/{saleId} {
      allow read, write: if request.auth != null;
    }

    // Puedes permitir escritura si tienes formularios tipo "editar perfil":
    // allow write: if request.auth != null && request.auth.uid == userId;
  }
}